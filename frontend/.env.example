# Asahlagi Frontend Environment Variables
# Copy to .env.development for local dev

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000

# Google login (OAuth — Google Identity Services).
# OAuth 2.0 Web client ID from Google Cloud Console. NOT a secret (it ships in
# the client bundle). Must match the backend's GOOGLE_CLIENT_ID. Configure the
# app origin under "Authorized JavaScript origins" for this client.
# If empty, the "Masuk dengan Google" button is hidden and the app runs in
# guest mode (anonymous device id).
# Format: <digits>-<hash>.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=
