# Asahlagi Backend Environment Variables
# Copy to .env for local dev

# Server config
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated origins allowed to call this backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ===== ML/DL inference =====
# Quiz generator runs DL inference via Hugging Face Space (cloud).
# Get this URL after deploying the Space at huggingface-space/.
# If empty, backend falls back to local CPU inference.
# Format: https://<username>-asahlagi-quizgen.hf.space
HF_SPACE_URL=

# ===== Database (gamification — Neon Postgres) =====
# Connection string from your Neon project (https://neon.tech).
# Paste the raw "postgresql://..." string; the backend rewrites the driver.
# If empty, gamification endpoints return 503 but core quiz features still work.
# Example: postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/asahlagi?sslmode=require
DATABASE_URL=

# ===== Google login (OAuth — Google Identity Services) =====
# OAuth 2.0 Web client ID from Google Cloud Console (APIs & Services > Credentials).
# Used to verify the audience of Google ID tokens. NOT a secret — same value the
# frontend uses (VITE_GOOGLE_CLIENT_ID). If empty, /auth/google returns 503 and
# the app stays in guest mode (anonymous device id).
# Format: <digits>-<hash>.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# ===== Asahi chatbot (GitHub Models) =====
# SECRET — server-side only, NEVER expose to the frontend. Used by POST /chat to
# call GitHub Models (OpenAI-compatible). Create a fine-grained PAT with "Models"
# read access at https://github.com/settings/tokens. If empty, /chat returns 503.
GITHUB_TOKEN=
